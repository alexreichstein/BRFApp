{
  "expo": {
    "name": "BRFApp",
    "slug": "BRFApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a4a0699b-9c89-42db-a529-7291e7c324ee"
      }
    },
    "owner": "yecko",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a4a0699b-9c89-42db-a529-7291e7c324ee"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Appen behöver kameran för att skanna dokument."
        }
      ]
    ]
  }
}